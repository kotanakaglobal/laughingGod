generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "sqlite"
  url      = env("DATABASE_URL")
}

model Session {
  id        String        @id @default(uuid())
  title     String
  date      DateTime
  status    SessionStatus @default(open)
  pinHash   String
  createdAt DateTime      @default(now())
  posts     Post[]
  votes     Vote[]
}

model Post {
  id             String   @id @default(uuid())
  sessionId      String
  authorNameRaw  String
  authorNameNorm String
  text           String
  createdAt      DateTime @default(now())
  session        Session  @relation(fields: [sessionId], references: [id], onDelete: Cascade)
  votes          Vote[]

  @@index([sessionId, createdAt])
}

model Vote {
  id            String   @id @default(uuid())
  sessionId     String
  voterNameRaw  String
  voterNameNorm String
  postId        String
  createdAt     DateTime @default(now())
  session       Session  @relation(fields: [sessionId], references: [id], onDelete: Cascade)
  post          Post     @relation(fields: [postId], references: [id], onDelete: Cascade)

  @@unique([sessionId, voterNameNorm, postId])
  @@index([sessionId, voterNameNorm])
}

enum SessionStatus {
  open
  closed
}
